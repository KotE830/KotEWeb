<ul class="nav-items">
  <li><a href="/contents">contents</a></li>
  
  <% if (!locals.isAuth) { %>
    <li><a href="/signup">signup</a></li>
    <li><a href="/login">login</a></li>
  <% } %>

  <% if (locals.isAuth) { %>
    <li id="profile">
      <a href="<%= locals.username %>">
        <img src="/images/assets/person/base-person.png" alt="<%= locals.username %> profile" />
        <p><%= locals.username %></p>
      </a>
    </li>
    <li>
      <form action="/logout" method="POST">
        <button>Logout</button>
      </form>
    </li>
  <% } %>
</ul>