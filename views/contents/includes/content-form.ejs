<form action="">
  <p>
    <label for="title">Title</label>
    <input type="text" id="title" name="title" value="<%= content.title %>" required>
  </p>

  <div>
    <p>
      <label for="image">Image</label>
      <input type="file" id="image" name="image" accept="iamge/png,image/jpg">
    </p>

    <img src="" alt="Selected image.">
  </div>

  <p>
    <label for="description">Description</label>
    <textarea id="description" name="description" row="7" required><%= content.description %></textarea>
  </p>

  <p>
    <button class="btn">Save</button>
  </p>
</form>